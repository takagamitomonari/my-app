<!DOCTYPE html>
<html lang="ja">
<head><meta charset="UTF-8"><title>わんこ名簿</title></head>
<body>
  <h1>ユーザー一覧</h1>
  <ul>
    <% users.forEach(user => { %>
      <li><%= user.name %></li>
    <% }) %>
  </ul>
  <form action="/users" method="post">
    <input type="text" name="name" placeholder="名前を入力" required>
    <button type="submit">追加</button>
  </form>
</body>
</html>
